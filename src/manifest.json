{
  "manifest_version": 3,
  "name": "umiriCopy",
  "version": "0.1.0",
  "description": "一键复制推文到剪贴板",
  "icons": {
    "32": "icons/icon32.png",
    "64": "icons/icon64.png"
  },
  "permissions": ["activeTab", "downloads", "storage"],
  "options_page": "options/index.html",
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_popup": "popup/index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*"],
      "js": ["content_scripts/twitterCopy.js"],
      "css": ["content_scripts/twitterCopy.css"]
    },
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content_scripts/instagramCopy.js"],
      "css": ["content_scripts/instagramCopy.css"]
    }
  ]
}
